{
  "manifest_version": "0.3",
  "name": "gordo-mcp",
  "version": "1.0.0-rc10",
  "description": "Reference library for AI agents building working agreements with their humans. Part of the Gordo human-AI collaboration framework.",
  "author": {
    "name": "Gordo",
    "email": "gordo@dashcord.com",
    "url": "https://github.com/gordo-ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jkraybill/gordo-forge"
  },
  "license": "MIT",
  "server": {
    "type": "node",
    "entry_point": "dist/cli.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/dist/cli.js"],
      "env": {}
    }
  },
  "keywords": [
    "mcp",
    "human-ai-collaboration",
    "bilateral-consent",
    "ai-constitution",
    "collaboration-framework",
    "ai-governance"
  ]
}
